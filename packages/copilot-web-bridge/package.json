{
  "name": "copilot-web-bridge",
  "version": "0.1.0",
  "description": "Use an authenticated Microsoft 365 Copilot Chat browser session through a local or SSH-stdio MCP server.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "copilot-web-bridge": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22 <27"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prepack": "npm run clean && npm run build",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "playwright-core": "^1.57.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
